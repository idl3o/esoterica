<%
// Channel metadata for display
var channelMeta = {
    'benjamin-davies': {
        name: 'Benjamin Davies',
        description: 'Paraphilosophy — exploring philosophy through a consciousness lens',
        color: '#00d4ff'
    },
    'swami-sarvapriyananda': {
        name: 'Swami Sarvapriyananda',
        description: 'Vedanta Society of New York — Advaita Vedanta teachings',
        color: '#ff6b6b'
    },
    'eckhart-tolle': {
        name: 'Eckhart Tolle',
        description: 'Presence, stillness, and the power of now',
        color: '#ffd93d'
    },
    'lex-fridman': {
        name: 'Lex Fridman Podcast',
        description: 'Deep conversations on consciousness, AI, and the nature of reality',
        color: '#6bcb77'
    },
    'robert-edward-grant': {
        name: 'Robert Edward Grant',
        description: 'Think Tank — mathematics, sacred geometry, and unified field theory',
        color: '#9d4edd'
    },
    'sadhguru': {
        name: 'Sadhguru',
        description: 'Inner engineering and yogic science',
        color: '#ff922b'
    },
    'after-skool': {
        name: 'After Skool',
        description: 'Animated wisdom from philosophers and teachers',
        color: '#4dabf7'
    },
    'batgap': {
        name: 'Buddha at the Gas Pump',
        description: 'Interviews with spiritually awakening people',
        color: '#f06595'
    },
    'ted': {
        name: 'TED Talks',
        description: 'Ideas worth spreading',
        color: '#e64980'
    },
    'theories-of-everything': {
        name: 'Theories of Everything',
        description: 'Curt Jaimungal — physics, consciousness, and philosophy',
        color: '#20c997'
    }
};

// Group by channel
var byChannel = {};
extractions.forEach(function(doc) {
    var ch = doc.channel || 'other';
    if (!byChannel[ch]) byChannel[ch] = [];
    byChannel[ch].push(doc);
});

// Sort channels by count (largest first)
var channelNames = Object.keys(byChannel).filter(function(ch) {
    return ch !== 'README.md' && ch !== 'harvest-the-question-the-game-the-arena.md';
}).sort(function(a, b) {
    return byChannel[b].length - byChannel[a].length;
});

var body = `
<style>
.extractions-hero {
    text-align: center;
    padding: 3rem 2rem 1rem;
}
.extractions-hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #ff6b6b 0%, #ffd93d 50%, #6bcb77 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.extractions-hero p {
    color: #888;
    font-size: 1.1rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
}
.extractions-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
}
.extractions-stat {
    text-align: center;
}
.extractions-stat .stat-value {
    font-size: 2rem;
    font-weight: bold;
    color: #00d4ff;
}
.extractions-stat .stat-label {
    font-size: 0.85rem;
    color: #666;
    letter-spacing: 0.1em;
    text-transform: uppercase;
}
.channels-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 2rem;
}
.channel-card {
    background: rgba(5, 5, 15, 0.8);
    border: 2px solid rgba(0, 212, 255, 0.15);
    border-radius: 10px;
    padding: 1.5rem;
    backdrop-filter: blur(15px);
    transition: all 0.3s;
}
.channel-card:hover {
    border-color: rgba(0, 212, 255, 0.4);
}
.channel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
}
.channel-name {
    font-size: 1.2rem;
    font-weight: bold;
    margin: 0;
}
.channel-count {
    background: rgba(0, 212, 255, 0.15);
    color: #00d4ff;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
}
.channel-desc {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    font-style: italic;
}
.channel-extractions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 300px;
    overflow-y: auto;
    padding-right: 0.5rem;
}
.channel-extractions::-webkit-scrollbar {
    width: 4px;
}
.channel-extractions::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 2px;
}
.channel-extractions::-webkit-scrollbar-thumb {
    background: rgba(0, 212, 255, 0.3);
    border-radius: 2px;
}
.extraction-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    text-decoration: none;
    transition: all 0.2s;
}
.extraction-item:hover {
    padding-left: 0.5rem;
}
.extraction-item:last-child {
    border-bottom: none;
}
.extraction-title {
    color: #e0e0e0;
    font-size: 0.9rem;
    line-height: 1.4;
    flex: 1;
    margin-right: 1rem;
}
.extraction-item:hover .extraction-title {
    color: #00d4ff;
}
.extraction-duration {
    color: #555;
    font-size: 0.8rem;
    white-space: nowrap;
}
.channel-footer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(0, 212, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: #666;
}
.channel-total-time {
    color: #888;
}
@media (max-width: 768px) {
    .extractions-hero h1 { font-size: 1.8rem; }
    .channels-grid {
        grid-template-columns: 1fr;
        padding: 0 1rem;
    }
    .extractions-stats {
        gap: 1rem;
    }
    .extractions-stat .stat-value {
        font-size: 1.5rem;
    }
}
</style>

<div class="extractions-hero">
    <h1>Source Transmissions</h1>
    <p>Raw wisdom harvested from teachers, philosophers, and seekers. Transcripts extracted and indexed for deep study.</p>
    <div class="extractions-stats">
        <div class="extractions-stat">
            <div class="stat-value">${stats.documentCount}</div>
            <div class="stat-label">Transcripts</div>
        </div>
        <div class="extractions-stat">
            <div class="stat-value">${Math.floor(stats.totalReadingTime / 60)}h</div>
            <div class="stat-label">Reading Time</div>
        </div>
        <div class="extractions-stat">
            <div class="stat-value">${Math.round(stats.totalWords / 1000)}k</div>
            <div class="stat-label">Words</div>
        </div>
        <div class="extractions-stat">
            <div class="stat-value">${channelNames.length}</div>
            <div class="stat-label">Channels</div>
        </div>
    </div>
</div>

<div class="channels-grid">
`;

channelNames.forEach(function(channelSlug) {
    var docs = byChannel[channelSlug];
    var meta = channelMeta[channelSlug] || { name: channelSlug.replace(/-/g, ' ').replace(/\b\w/g, function(l) { return l.toUpperCase(); }), description: '', color: '#00d4ff' };
    var totalMinutes = docs.reduce(function(sum, d) { return sum + d.readingTime; }, 0);

    body += '<div class="channel-card" style="border-color: ' + meta.color + '20;">';
    body += '<div class="channel-header">';
    body += '<h2 class="channel-name" style="color: ' + meta.color + ';">' + meta.name + '</h2>';
    body += '<span class="channel-count">' + docs.length + '</span>';
    body += '</div>';
    if (meta.description) {
        body += '<div class="channel-desc">' + meta.description + '</div>';
    }
    body += '<div class="channel-extractions">';

    docs.forEach(function(doc) {
        var displayTitle = doc.title.length > 70 ? doc.title.substring(0, 67) + '...' : doc.title;
        body += '<a class="extraction-item" href="/read/' + doc.path + '">';
        body += '<span class="extraction-title">' + displayTitle + '</span>';
        body += '<span class="extraction-duration">' + doc.readingTime + ' min</span>';
        body += '</a>';
    });

    body += '</div>';
    body += '<div class="channel-footer">';
    body += '<span class="channel-total-time">' + Math.floor(totalMinutes / 60) + 'h ' + (totalMinutes % 60) + 'm total reading</span>';
    body += '</div>';
    body += '</div>';
});

body += `
</div>
`;
%>
<%- include('layout', { title: title, body: body }) %>
