---
/**
 * Item Detail Page - full history of a single zeitgeist item.
 */

import Base from '../../../../layouts/Base.astro';
import Sparkline from '../../../../components/Sparkline.astro';
import {
  loadZeitgeistItems,
  type ZeitgeistItem,
  type Timescale,
} from '../../../../lib/zeitgeist-index';

export function getStaticPaths() {
  const index = loadZeitgeistItems();
  return index.items.map(item => ({
    params: { id: item.id },
    props: { item },
  }));
}

interface Props {
  item: ZeitgeistItem;
}

const { item } = Astro.props;
const index = loadZeitgeistItems();

// Build appearance map for sparkline (oldest first)
const sortedDates = [...index.allDates].reverse();
const appearanceDates = new Set(item.appearances.map(a => a.date));
const appearances = sortedDates.map(date => appearanceDates.has(date));

// Sort appearances newest first for display
const sortedAppearances = [...item.appearances].reverse();

// Timescale styling
const timescaleStyles: Record<Timescale, { text: string; border: string; bg: string }> = {
  SURFACE: { text: 'text-text-secondary', border: 'border-text-secondary/30', bg: 'bg-text-secondary/10' },
  CURRENT: { text: 'text-cyan', border: 'border-cyan/30', bg: 'bg-cyan/10' },
  DEEP: { text: 'text-purple', border: 'border-purple/30', bg: 'bg-purple/10' },
  TECTONIC: { text: 'text-green', border: 'border-green/30', bg: 'bg-green/10' },
};

const style = timescaleStyles[item.timescale];

// Status styling
const statusStyles: Record<string, { text: string; label: string }> = {
  active: { text: 'text-cyan', label: 'Active' },
  metabolised: { text: 'text-text-muted', label: 'Metabolised' },
  dormant: { text: 'text-purple', label: 'Dormant' },
};

const statusStyle = statusStyles[item.status];
---

<Base title={`${item.title} | Meta-Zeitgeist`} description={item.latestDescription?.substring(0, 160)}>
  <div class="max-w-4xl mx-auto px-6 py-12">
    <!-- Breadcrumb -->
    <div class="mb-8">
      <a
        href="/zeitgeist/meta"
        class="text-xs uppercase tracking-label text-text-muted hover:text-cyan transition-colors duration-300"
      >
        ← Meta-Zeitgeist
      </a>
      <span class="text-text-muted/50 mx-2">/</span>
      <a
        href={`/zeitgeist/meta/${item.timescale.toLowerCase()}`}
        class:list={["text-xs uppercase tracking-label transition-colors duration-300", style.text]}
      >
        {item.timescale}
      </a>
    </div>

    <!-- Header -->
    <div class="mb-8">
      <h1 class:list={["text-3xl md:text-4xl font-light tracking-wide mb-4", style.text]}>
        {item.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 mb-6">
        <span class:list={[
          "text-xs uppercase tracking-label px-3 py-1 rounded border",
          style.text, style.border, style.bg
        ]}>
          {item.timescale}
        </span>
        <span class:list={["text-sm", statusStyle.text]}>
          {statusStyle.label}
        </span>
        <span class="text-sm text-text-muted">
          {item.appearanceCount} appearances over {item.daysPersisted} days
        </span>
      </div>

      <div class="flex items-center gap-4">
        <span class="text-xs text-text-muted">Persistence:</span>
        <Sparkline
          appearances={appearances}
          timescale={item.timescale}
          width={200}
          height={20}
        />
      </div>
    </div>

    <!-- Title Variants -->
    {item.titleVariants.length > 1 && (
      <div class="mb-8 glass p-4">
        <h2 class="text-xs uppercase tracking-label text-text-muted mb-3">Title Variants</h2>
        <div class="flex flex-wrap gap-2">
          {item.titleVariants.map(variant => (
            <span class="text-sm text-text-secondary px-2 py-1 bg-white/5 rounded">
              {variant}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Latest Processing Gap -->
    {item.latestGap && (
      <div class="mb-10 glass p-6 border-l-2 border-purple">
        <h2 class="text-xs uppercase tracking-label text-purple mb-3">Latest Processing Gap</h2>
        <p class="text-text-secondary italic leading-relaxed">
          {item.latestGap}
        </p>
      </div>
    )}

    <!-- Appearance Timeline -->
    <section class="mb-10">
      <h2 class="text-xl font-light text-text-secondary mb-6">Appearances</h2>

      <div class="space-y-6">
        {sortedAppearances.map((appearance, i) => {
          const appStyle = timescaleStyles[appearance.timescale];
          const isFirst = i === 0;

          return (
            <div class:list={[
              "glass p-5",
              isFirst && "border-cyan/50"
            ]}>
              <div class="flex items-baseline justify-between mb-3">
                <a
                  href={`/zeitgeist/${appearance.date}`}
                  class="text-sm text-cyan hover:text-white transition-colors duration-300"
                >
                  {appearance.date}
                </a>
                <span class:list={[
                  "text-xs uppercase tracking-label px-2 py-0.5 rounded border",
                  appStyle.text, appStyle.border, appStyle.bg
                ]}>
                  {appearance.timescale}
                </span>
              </div>

              {appearance.title !== item.title && (
                <p class="text-sm text-text-muted mb-2">
                  As: "{appearance.title}"
                </p>
              )}

              <p class="text-sm text-text-secondary leading-relaxed mb-3">
                {appearance.description.substring(0, 500)}
                {appearance.description.length > 500 && '...'}
              </p>

              {appearance.gap && (
                <p class="text-xs text-purple italic border-l-2 border-purple/30 pl-3">
                  {appearance.gap}
                </p>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <!-- All Gaps Collected -->
    {sortedAppearances.filter(a => a.gap).length > 1 && (
      <section class="mb-10">
        <h2 class="text-xl font-light text-purple mb-4">All Processing Gaps</h2>
        <p class="text-xs text-text-muted italic mb-6">
          The silences across readings — how the collective has (not) processed this signal.
        </p>

        <div class="space-y-4">
          {sortedAppearances.filter(a => a.gap).map(a => (
            <div class="glass p-4 border-l-2 border-purple/30">
              <span class="text-xs text-text-muted">{a.date}:</span>
              <p class="text-sm text-text-secondary italic mt-1">{a.gap}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Navigation -->
    <div class="mt-12 pt-8 border-t border-white/10 flex justify-between items-center">
      <a
        href={`/zeitgeist/meta/${item.timescale.toLowerCase()}`}
        class="text-sm text-text-muted hover:text-cyan transition-colors duration-300"
      >
        ← All {item.timescale} items
      </a>
      <a
        href="/zeitgeist/meta"
        class="text-sm text-text-muted hover:text-cyan transition-colors duration-300"
      >
        Meta-Zeitgeist →
      </a>
    </div>
  </div>
</Base>
