---
import type { ZeitgeistReading } from '../lib/zeitgeist';

interface Props {
  reading: ZeitgeistReading;
}

const { reading } = Astro.props;
---

<a href={`/zeitgeist/${reading.date}`} class="block glass p-6 transition-lift hover:border-cyan-glow group max-w-2xl mx-auto">
  <div class="flex items-center gap-2 mb-2">
    <span class="text-xs uppercase tracking-label text-green">Latest Reading</span>
    <span class="text-xs text-text-muted">{reading.displayDate}</span>
  </div>
  {reading.headline && (
    <h3 class="text-lg text-cyan group-hover:text-green transition-colors duration-300">
      {reading.headline}
    </h3>
  )}
  {reading.summary && (
    <p class="text-sm text-text-secondary mt-2 line-clamp-2">{reading.summary}</p>
  )}
</a>
