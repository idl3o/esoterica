---
import Base from '../layouts/Base.astro';
import { getAllNodes, formatNodeName } from '../lib/constellation';
import { getDomainForType, DOMAINS } from '../lib/domains';
import { loadDocumentLinks } from '../lib/content';

const allNodes = getAllNodes();
const links = loadDocumentLinks();

const nodes = Object.entries(allNodes).map(([id, node]) => ({
  id,
  type: node.type,
  essence: node.essence,
  connections: node.connections || [],
  domain: getDomainForType(node.type),
}));

const nodeDocs: Record<string, { title: string; path: string }[]> = {};
for (const [nodeId, docs] of Object.entries(links.nodeToDocuments)) {
  nodeDocs[nodeId] = docs.slice(0, 6).map(d => ({
    title: d.title, path: '/read/' + d.path,
  }));
}

const domainColors: Record<string, string> = {
  archetypes:                '#e06c75',
  consciousness_technologies:'#00d4ff',
  elements_primordials:      '#d19a66',
  cosmological:              '#c678dd',
  glyph_systems:             '#e5c07b',
  theoretical:               '#61afef',
  processes:                 '#00ff88',
  states:                    '#56b6c2',
  traditions:                '#be5046',
  concepts:                  '#abb2bf',
  meta:                      '#9d4edd',
  applications:              '#98c379',
};

const domainLabels: Record<string, string> = {};
for (const [id, d] of Object.entries(DOMAINS)) {
  domainLabels[id] = d.label;
}
---

<Base title="Constellation Explorer" description="Navigate the living constellation — 2D force-directed graph">
  <div id="explorer-wrap" style="position:relative; width:100%; height:calc(100vh - 4rem); overflow:hidden; background:#0a0a0f;">
    <canvas id="constellation-canvas" style="display:block; width:100%; height:100%;"></canvas>

    <!-- Domain legend -->
    <div id="legend" style="position:absolute; top:12px; left:12px; display:flex; flex-wrap:wrap; gap:6px; max-width:320px; pointer-events:none; opacity:0.7;">
    </div>

    <!-- Node count -->
    <div id="node-count" style="position:absolute; bottom:12px; left:12px; font-size:11px; color:#888; pointer-events:none;"></div>

    <!-- 3D link -->
    <a href="/explorer.html" id="three-d-link"
       style="position:absolute; bottom:12px; right:12px; font-size:11px; color:#00d4ff; opacity:0.6; text-decoration:none; padding:6px 10px; border:1px solid rgba(0,212,255,0.3); border-radius:6px;"
       onmouseenter="this.style.opacity='1'" onmouseleave="this.style.opacity='0.6'">
      Launch 3D Explorer
    </a>

    <!-- Info panel -->
    <div id="info-panel" style="display:none;">
      <button id="info-close" aria-label="Close">&times;</button>
      <h2 id="info-name"></h2>
      <p id="info-essence" style="color:#aaa; font-size:13px; margin:6px 0 10px; line-height:1.5;"></p>
      <div id="info-meta" style="font-size:11px; color:#888; margin-bottom:12px;"></div>
      <div id="info-connections"></div>
      <div id="info-docs"></div>
    </div>

    <!-- Tooltip -->
    <div id="tooltip" style="display:none; position:absolute; pointer-events:none; background:rgba(10,10,15,0.92); border:1px solid rgba(0,212,255,0.3); border-radius:4px; padding:4px 8px; font-size:12px; color:#e0e0e0; white-space:nowrap; z-index:20;"></div>
  </div>
</Base>

<style is:global>
  /* Hide footer on explorer page */
  footer { display: none !important; }

  #info-panel {
    position: absolute;
    background: rgba(10, 10, 15, 0.95);
    border: 1px solid rgba(0, 212, 255, 0.2);
    backdrop-filter: blur(12px);
    overflow-y: auto;
    z-index: 10;
    padding: 20px;
    scrollbar-width: thin;
    scrollbar-color: #333 transparent;
  }

  /* Desktop: right sidebar */
  @media (min-width: 768px) {
    #info-panel {
      top: 0; right: 0; bottom: 0;
      width: 340px;
      border-left: 1px solid rgba(0, 212, 255, 0.15);
      border-radius: 0;
    }
  }

  /* Mobile: bottom sheet */
  @media (max-width: 767px) {
    #info-panel {
      left: 0; right: 0; bottom: 0;
      max-height: 55vh;
      border-top: 1px solid rgba(0, 212, 255, 0.15);
      border-radius: 12px 12px 0 0;
    }
  }

  #info-close {
    position: absolute; top: 12px; right: 14px;
    background: none; border: none; color: #888; font-size: 22px; cursor: pointer; line-height: 1;
  }
  #info-close:hover { color: #e0e0e0; }

  #info-name {
    font-size: 18px; font-weight: 400; color: #e0e0e0; margin: 0 0 2px;
    letter-spacing: 0.02em;
  }

  .info-section-label {
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: #666; margin: 14px 0 6px;
  }

  .conn-link, .doc-link {
    display: block; padding: 5px 8px; margin: 2px 0; border-radius: 4px;
    font-size: 12px; color: #aaa; cursor: pointer; text-decoration: none;
    transition: background 0.15s;
  }
  .conn-link:hover, .doc-link:hover { background: rgba(0, 212, 255, 0.08); color: #e0e0e0; }
  .doc-link { color: #00d4ff; }
</style>

<script define:vars={{ nodes, nodeDocs, domainColors, domainLabels }}>
(function() {
  const canvas = document.getElementById('constellation-canvas');
  const ctx = canvas.getContext('2d');
  const wrap = document.getElementById('explorer-wrap');
  const tooltip = document.getElementById('tooltip');
  const panel = document.getElementById('info-panel');
  const dpr = window.devicePixelRatio || 1;

  // --- Resize ---
  function resize() {
    const rect = wrap.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  // --- Build graph data ---
  const idIndex = {};
  const graphNodes = nodes.map((n, i) => {
    idIndex[n.id] = i;
    return {
      id: n.id,
      type: n.type,
      essence: n.essence,
      domain: n.domain,
      connections: n.connections,
      color: domainColors[n.domain] || '#abb2bf',
      mass: 1 + (n.connections ? n.connections.length : 0),
      x: 0, y: 0, vx: 0, vy: 0,
      pinned: false,
    };
  });

  // Initial positions: clustered by domain with randomness
  const domainCenters = {};
  const domainIds = Object.keys(domainColors);
  const cx = canvas.width / dpr / 2, cy = canvas.height / dpr / 2;
  const spread = Math.min(cx, cy) * 0.7;
  domainIds.forEach((d, i) => {
    const angle = (i / domainIds.length) * Math.PI * 2;
    domainCenters[d] = { x: cx + Math.cos(angle) * spread * 0.5, y: cy + Math.sin(angle) * spread * 0.5 };
  });

  graphNodes.forEach(n => {
    const c = domainCenters[n.domain] || { x: cx, y: cy };
    n.x = c.x + (Math.random() - 0.5) * spread * 0.6;
    n.y = c.y + (Math.random() - 0.5) * spread * 0.6;
  });

  // Build edges (only where both endpoints exist)
  const edges = [];
  const edgeSet = new Set();
  graphNodes.forEach(n => {
    if (!n.connections) return;
    n.connections.forEach(targetId => {
      if (idIndex[targetId] === undefined) return;
      const key = n.id < targetId ? n.id + '|' + targetId : targetId + '|' + n.id;
      if (edgeSet.has(key)) return;
      edgeSet.add(key);
      edges.push([idIndex[n.id], idIndex[targetId]]);
    });
  });

  // --- Legend ---
  const legend = document.getElementById('legend');
  const activeDomains = new Set(graphNodes.map(n => n.domain));
  domainIds.filter(d => activeDomains.has(d)).forEach(d => {
    const el = document.createElement('span');
    el.style.cssText = `font-size:10px; color:${domainColors[d]}; opacity:0.9;`;
    el.textContent = (domainLabels[d] || d);
    legend.appendChild(el);
  });

  document.getElementById('node-count').textContent = graphNodes.length + ' nodes · ' + edges.length + ' connections';

  // --- Camera ---
  let camX = 0, camY = 0, camZoom = 1;

  function worldToScreen(wx, wy) {
    const sw = canvas.width / dpr, sh = canvas.height / dpr;
    return {
      x: (wx - camX) * camZoom + sw / 2,
      y: (wy - camY) * camZoom + sh / 2,
    };
  }
  function screenToWorld(sx, sy) {
    const sw = canvas.width / dpr, sh = canvas.height / dpr;
    return {
      x: (sx - sw / 2) / camZoom + camX,
      y: (sy - sh / 2) / camZoom + camY,
    };
  }

  // Center camera on centroid
  let sumX = 0, sumY = 0;
  graphNodes.forEach(n => { sumX += n.x; sumY += n.y; });
  camX = sumX / graphNodes.length;
  camY = sumY / graphNodes.length;
  camZoom = Math.min(1, 600 / spread);

  // --- Physics ---
  const SPRING_LENGTH = 80;
  const SPRING_K = 0.003;
  const REPULSION = 800;
  const DAMPING = 0.9;
  const CENTER_PULL = 0.0001;
  let simActive = true;
  let simFrame = 0;
  const MAX_SIM_FRAMES = 400;

  // Spatial grid for repulsion optimization
  function simulate() {
    if (!simActive) return;
    const N = graphNodes.length;

    // Center of mass
    let mx = 0, my = 0;
    for (let i = 0; i < N; i++) { mx += graphNodes[i].x; my += graphNodes[i].y; }
    mx /= N; my /= N;

    // Repulsion (use grid-based approximation for large N)
    const CELL = 120;
    const grid = {};
    for (let i = 0; i < N; i++) {
      const n = graphNodes[i];
      const gx = Math.floor(n.x / CELL), gy = Math.floor(n.y / CELL);
      const key = gx + ',' + gy;
      if (!grid[key]) grid[key] = [];
      grid[key].push(i);
    }

    for (let i = 0; i < N; i++) {
      const a = graphNodes[i];
      if (a.pinned) continue;
      const gx = Math.floor(a.x / CELL), gy = Math.floor(a.y / CELL);

      // Check 5x5 neighborhood
      for (let dx = -2; dx <= 2; dx++) {
        for (let dy = -2; dy <= 2; dy++) {
          const cell = grid[(gx + dx) + ',' + (gy + dy)];
          if (!cell) continue;
          for (let k = 0; k < cell.length; k++) {
            const j = cell[k];
            if (j <= i) continue;
            const b = graphNodes[j];
            let ddx = a.x - b.x, ddy = a.y - b.y;
            let dist = Math.sqrt(ddx * ddx + ddy * ddy) || 1;
            if (dist > CELL * 3) continue;
            const force = REPULSION / (dist * dist);
            const fx = ddx / dist * force, fy = ddy / dist * force;
            a.vx += fx; a.vy += fy;
            if (!b.pinned) { b.vx -= fx; b.vy -= fy; }
          }
        }
      }

      // Centering
      a.vx += (mx - a.x) * CENTER_PULL;
      a.vy += (my - a.y) * CENTER_PULL;
    }

    // Spring forces on edges
    for (let e = 0; e < edges.length; e++) {
      const a = graphNodes[edges[e][0]], b = graphNodes[edges[e][1]];
      const ddx = b.x - a.x, ddy = b.y - a.y;
      const dist = Math.sqrt(ddx * ddx + ddy * ddy) || 1;
      const displacement = dist - SPRING_LENGTH;
      const force = SPRING_K * displacement;
      const fx = ddx / dist * force, fy = ddy / dist * force;
      if (!a.pinned) { a.vx += fx; a.vy += fy; }
      if (!b.pinned) { b.vx -= fx; b.vy -= fy; }
    }

    // Integrate
    let totalV = 0;
    for (let i = 0; i < N; i++) {
      const n = graphNodes[i];
      if (n.pinned) { n.vx = 0; n.vy = 0; continue; }
      n.vx *= DAMPING; n.vy *= DAMPING;
      // Clamp velocity
      const v = Math.sqrt(n.vx * n.vx + n.vy * n.vy);
      if (v > 10) { n.vx = n.vx / v * 10; n.vy = n.vy / v * 10; }
      n.x += n.vx; n.y += n.vy;
      totalV += v;
    }

    simFrame++;
    if (simFrame > MAX_SIM_FRAMES && totalV / N < 0.05) simActive = false;
  }

  // --- Render ---
  let selectedIdx = -1;
  let hoveredIdx = -1;
  const selectedConnSet = new Set();

  function nodeRadius(n) {
    return Math.max(2.5, Math.min(8, 1.5 + Math.sqrt(n.mass) * 1.5));
  }

  function draw() {
    const sw = canvas.width / dpr, sh = canvas.height / dpr;
    ctx.clearRect(0, 0, sw, sh);

    // Edges
    ctx.lineWidth = 0.5;
    for (let e = 0; e < edges.length; e++) {
      const a = graphNodes[edges[e][0]], b = graphNodes[edges[e][1]];
      const sa = worldToScreen(a.x, a.y), sb = worldToScreen(b.x, b.y);

      // Cull offscreen
      if ((sa.x < -50 && sb.x < -50) || (sa.x > sw + 50 && sb.x > sw + 50)) continue;
      if ((sa.y < -50 && sb.y < -50) || (sa.y > sh + 50 && sb.y > sh + 50)) continue;

      const isHighlighted = selectedIdx >= 0 &&
        (edges[e][0] === selectedIdx || edges[e][1] === selectedIdx);

      ctx.strokeStyle = isHighlighted ? 'rgba(0, 212, 255, 0.5)' : 'rgba(255,255,255,0.06)';
      ctx.lineWidth = isHighlighted ? 1 : 0.5;
      ctx.beginPath();
      ctx.moveTo(sa.x, sa.y);
      ctx.lineTo(sb.x, sb.y);
      ctx.stroke();
    }

    // Nodes
    for (let i = 0; i < graphNodes.length; i++) {
      const n = graphNodes[i];
      const s = worldToScreen(n.x, n.y);

      // Cull offscreen
      if (s.x < -20 || s.x > sw + 20 || s.y < -20 || s.y > sh + 20) continue;

      const r = nodeRadius(n) * camZoom;
      const isSelected = i === selectedIdx;
      const isConnected = selectedConnSet.has(i);
      const isHovered = i === hoveredIdx;
      const dimmed = selectedIdx >= 0 && !isSelected && !isConnected;

      ctx.beginPath();
      ctx.arc(s.x, s.y, Math.max(r, 1.5), 0, Math.PI * 2);

      if (isSelected) {
        ctx.fillStyle = '#fff';
        ctx.shadowColor = n.color;
        ctx.shadowBlur = 12;
      } else if (isConnected) {
        ctx.fillStyle = n.color;
        ctx.shadowColor = n.color;
        ctx.shadowBlur = 6;
      } else if (isHovered) {
        ctx.fillStyle = n.color;
        ctx.shadowColor = n.color;
        ctx.shadowBlur = 8;
      } else {
        ctx.fillStyle = dimmed ? 'rgba(255,255,255,0.08)' : n.color;
        ctx.shadowBlur = 0;
      }

      ctx.fill();
      ctx.shadowBlur = 0;

      // Label for selected/hovered or large nodes when zoomed
      if ((isSelected || isHovered || (isConnected && camZoom > 0.8)) && camZoom > 0.4) {
        ctx.fillStyle = isSelected ? '#fff' : (isConnected ? '#ccc' : '#aaa');
        ctx.font = (isSelected ? '12px' : '10px') + " 'Segoe UI', sans-serif";
        ctx.textAlign = 'center';
        ctx.fillText(formatName(n.id), s.x, s.y - r - 4);
      }
    }
  }

  function formatName(id) {
    return id.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
  }

  // --- Hit test ---
  function hitTest(sx, sy) {
    const w = screenToWorld(sx, sy);
    let bestIdx = -1, bestDist = Infinity;
    const hitRadius = Math.max(22, 22 / camZoom); // 44px touch target (22px radius) min
    for (let i = 0; i < graphNodes.length; i++) {
      const n = graphNodes[i];
      const dx = n.x - w.x, dy = n.y - w.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const r = nodeRadius(n) + hitRadius / camZoom;
      if (dist < r && dist < bestDist) {
        bestDist = dist;
        bestIdx = i;
      }
    }
    return bestIdx;
  }

  // --- Info panel ---
  function showInfo(idx) {
    if (idx < 0) { panel.style.display = 'none'; return; }
    const n = graphNodes[idx];
    document.getElementById('info-name').textContent = formatName(n.id);
    document.getElementById('info-name').style.color = n.color;
    document.getElementById('info-essence').textContent = n.essence || '';
    document.getElementById('info-meta').innerHTML =
      '<span style="color:' + n.color + '">' + (domainLabels[n.domain] || n.domain) + '</span>' +
      ' · <span>' + n.type.replace(/_/g, ' ') + '</span>' +
      ' · <span>' + (n.connections ? n.connections.length : 0) + ' connections</span>';

    // Connections
    const connDiv = document.getElementById('info-connections');
    const validConns = (n.connections || []).filter(c => idIndex[c] !== undefined);
    if (validConns.length) {
      connDiv.innerHTML = '<div class="info-section-label">Connected Nodes</div>';
      validConns.slice(0, 20).forEach(cid => {
        const a = document.createElement('a');
        a.className = 'conn-link';
        a.textContent = formatName(cid);
        const ci = idIndex[cid];
        if (ci !== undefined) {
          a.style.color = graphNodes[ci].color;
        }
        a.href = '#';
        a.onclick = function(e) { e.preventDefault(); selectNode(idIndex[cid]); };
        connDiv.appendChild(a);
      });
    } else {
      connDiv.innerHTML = '';
    }

    // Documents
    const docsDiv = document.getElementById('info-docs');
    const docs = nodeDocs[n.id];
    if (docs && docs.length) {
      docsDiv.innerHTML = '<div class="info-section-label">Documents</div>';
      docs.forEach(d => {
        const a = document.createElement('a');
        a.className = 'doc-link';
        a.textContent = d.title;
        a.href = d.path;
        docsDiv.appendChild(a);
      });
    } else {
      docsDiv.innerHTML = '';
    }

    panel.style.display = 'block';
  }

  function selectNode(idx) {
    selectedIdx = idx;
    selectedConnSet.clear();
    if (idx >= 0) {
      const n = graphNodes[idx];
      (n.connections || []).forEach(cid => {
        if (idIndex[cid] !== undefined) selectedConnSet.add(idIndex[cid]);
      });
      // Animate camera to selected node
      const target = { x: n.x, y: n.y };
      const startX = camX, startY = camY;
      const startT = performance.now();
      const dur = 300;
      function animateCam(t) {
        const p = Math.min(1, (t - startT) / dur);
        const ease = p * (2 - p); // ease-out
        camX = startX + (target.x - startX) * ease;
        camY = startY + (target.y - startY) * ease;
        if (p < 1) requestAnimationFrame(animateCam);
      }
      requestAnimationFrame(animateCam);
    }
    showInfo(idx);
  }

  document.getElementById('info-close').onclick = function() {
    selectedIdx = -1;
    selectedConnSet.clear();
    panel.style.display = 'none';
  };

  // --- Interaction state ---
  let isDragging = false;
  let isPanning = false;
  let dragIdx = -1;
  let panStartX = 0, panStartY = 0;
  let panCamStartX = 0, panCamStartY = 0;
  let pointerDownTime = 0;

  function getCanvasPos(e) {
    const rect = canvas.getBoundingClientRect();
    if (e.touches) {
      return { x: e.touches[0].clientX - rect.left, y: e.touches[0].clientY - rect.top };
    }
    return { x: e.clientX - rect.left, y: e.clientY - rect.top };
  }

  // --- Mouse events ---
  canvas.addEventListener('mousedown', function(e) {
    const pos = getCanvasPos(e);
    const hit = hitTest(pos.x, pos.y);
    pointerDownTime = performance.now();
    if (hit >= 0) {
      dragIdx = hit;
      isDragging = true;
      graphNodes[hit].pinned = true;
    } else {
      isPanning = true;
      panStartX = pos.x; panStartY = pos.y;
      panCamStartX = camX; panCamStartY = camY;
    }
  });

  canvas.addEventListener('mousemove', function(e) {
    const pos = getCanvasPos(e);
    if (isDragging && dragIdx >= 0) {
      const w = screenToWorld(pos.x, pos.y);
      graphNodes[dragIdx].x = w.x;
      graphNodes[dragIdx].y = w.y;
      simActive = true; simFrame = 0;
    } else if (isPanning) {
      const dx = pos.x - panStartX, dy = pos.y - panStartY;
      camX = panCamStartX - dx / camZoom;
      camY = panCamStartY - dy / camZoom;
    } else {
      // Hover
      const hit = hitTest(pos.x, pos.y);
      hoveredIdx = hit;
      canvas.style.cursor = hit >= 0 ? 'pointer' : 'grab';
      if (hit >= 0) {
        tooltip.textContent = formatName(graphNodes[hit].id);
        tooltip.style.display = 'block';
        tooltip.style.left = (pos.x + 14) + 'px';
        tooltip.style.top = (pos.y - 10) + 'px';
        tooltip.style.borderColor = graphNodes[hit].color + '66';
      } else {
        tooltip.style.display = 'none';
      }
    }
  });

  canvas.addEventListener('mouseup', function(e) {
    if (isDragging && dragIdx >= 0) {
      const elapsed = performance.now() - pointerDownTime;
      if (elapsed < 250) {
        // Click — select
        selectNode(dragIdx);
      }
      graphNodes[dragIdx].pinned = false;
    }
    if (isPanning) {
      const elapsed = performance.now() - pointerDownTime;
      const pos = getCanvasPos(e);
      const moved = Math.abs(pos.x - panStartX) + Math.abs(pos.y - panStartY);
      if (elapsed < 250 && moved < 5) {
        // Click on empty — deselect
        selectedIdx = -1;
        selectedConnSet.clear();
        panel.style.display = 'none';
      }
    }
    isDragging = false;
    isPanning = false;
    dragIdx = -1;
  });

  canvas.addEventListener('mouseleave', function() {
    tooltip.style.display = 'none';
    hoveredIdx = -1;
  });

  // Zoom
  canvas.addEventListener('wheel', function(e) {
    e.preventDefault();
    const pos = getCanvasPos(e);
    const wBefore = screenToWorld(pos.x, pos.y);
    const factor = e.deltaY > 0 ? 0.9 : 1.1;
    camZoom = Math.max(0.1, Math.min(5, camZoom * factor));
    const wAfter = screenToWorld(pos.x, pos.y);
    camX -= (wAfter.x - wBefore.x);
    camY -= (wAfter.y - wBefore.y);
  }, { passive: false });

  // --- Touch events ---
  let lastTouchDist = 0;
  let touchCount = 0;

  canvas.addEventListener('touchstart', function(e) {
    e.preventDefault();
    touchCount = e.touches.length;
    if (e.touches.length === 1) {
      const pos = getCanvasPos(e);
      const hit = hitTest(pos.x, pos.y);
      pointerDownTime = performance.now();
      if (hit >= 0) {
        dragIdx = hit;
        isDragging = true;
        graphNodes[hit].pinned = true;
      } else {
        isPanning = true;
        panStartX = pos.x; panStartY = pos.y;
        panCamStartX = camX; panCamStartY = camY;
      }
    } else if (e.touches.length === 2) {
      isDragging = false; isPanning = false;
      if (dragIdx >= 0) graphNodes[dragIdx].pinned = false;
      dragIdx = -1;
      const dx = e.touches[0].clientX - e.touches[1].clientX;
      const dy = e.touches[0].clientY - e.touches[1].clientY;
      lastTouchDist = Math.sqrt(dx * dx + dy * dy);
    }
  }, { passive: false });

  canvas.addEventListener('touchmove', function(e) {
    e.preventDefault();
    if (e.touches.length === 1) {
      const pos = getCanvasPos(e);
      if (isDragging && dragIdx >= 0) {
        const w = screenToWorld(pos.x, pos.y);
        graphNodes[dragIdx].x = w.x;
        graphNodes[dragIdx].y = w.y;
        simActive = true; simFrame = 0;
      } else if (isPanning) {
        const dx = pos.x - panStartX, dy = pos.y - panStartY;
        camX = panCamStartX - dx / camZoom;
        camY = panCamStartY - dy / camZoom;
      }
    } else if (e.touches.length === 2) {
      const dx = e.touches[0].clientX - e.touches[1].clientX;
      const dy = e.touches[0].clientY - e.touches[1].clientY;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (lastTouchDist > 0) {
        const factor = dist / lastTouchDist;
        const rect = canvas.getBoundingClientRect();
        const mx = (e.touches[0].clientX + e.touches[1].clientX) / 2 - rect.left;
        const my = (e.touches[0].clientY + e.touches[1].clientY) / 2 - rect.top;
        const wBefore = screenToWorld(mx, my);
        camZoom = Math.max(0.1, Math.min(5, camZoom * factor));
        const wAfter = screenToWorld(mx, my);
        camX -= (wAfter.x - wBefore.x);
        camY -= (wAfter.y - wBefore.y);
      }
      lastTouchDist = dist;
    }
  }, { passive: false });

  canvas.addEventListener('touchend', function(e) {
    if (isDragging && dragIdx >= 0) {
      const elapsed = performance.now() - pointerDownTime;
      if (elapsed < 300 && touchCount === 1) {
        selectNode(dragIdx);
      }
      graphNodes[dragIdx].pinned = false;
    }
    if (isPanning && touchCount === 1) {
      const elapsed = performance.now() - pointerDownTime;
      if (elapsed < 300) {
        selectedIdx = -1;
        selectedConnSet.clear();
        panel.style.display = 'none';
      }
    }
    isDragging = false;
    isPanning = false;
    dragIdx = -1;
    lastTouchDist = 0;
  });

  // --- Animation loop ---
  function tick() {
    simulate();
    draw();
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();
</script>
