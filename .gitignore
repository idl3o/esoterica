.DS_Store
**/.DS_Store

# Claude configuration files (user-specific)
.claude/settings.local.json

# Markdown linting configuration (user-specific)
.markdownlint.json

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# site/package-lock.json is deliberately committed. Vercel runs `npm install`
# fresh on every deploy, so without a lockfile the build resolves whatever the
# registry offers that day — which is how @tailwindcss/vite 4.3.0 (2026-05-08)
# widened its vite peer to ^8 and broke the build without a commit touching it.

# Environment variables
.env
.env.local
.env.*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
Thumbs.db

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# World Model data (generated, not source)
world-model/data/
world-model/__pycache__/
world-model/src/__pycache__/
world-model/src/**/__pycache__/
*.pyc
*.pyo

# Astro build output
dist/
.astro/

# Temporary files
tmpclaude-*

# Sweep pipeline working artifacts (regenerated by cli/find_empty_nodes.py etc.)
cli/output/

# Generated from constellation/constellation.json by site/scripts/sync-public-data.mjs
site/public/constellation.json
